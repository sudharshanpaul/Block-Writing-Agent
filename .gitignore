venv/
.venv/
ENV/
env/

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# Backend
backend/images/
backend/history/
backend/*.log

# Frontend
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# System files
*.swp
*.swo

# Ignore requirements lock files
poetry.lock
Pipfile.lock

# Ignore research cache or temp files
*.tmp
*.bak

